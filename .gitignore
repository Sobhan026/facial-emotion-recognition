# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*

# Jupyter
.ipynb_checkpoints/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Large dataset files
data/raw/*.csv
data/raw/*.zip
data/raw/*.tar
data/raw/*.tar.gz

# Processed data artifacts
data/processed/*.npz
data/processed/*.npy

# Trained models
models/*.keras
models/*.h5

# Generated outputs
outputs/figures/*.png
outputs/figures/*.jpg
outputs/figures/*.jpeg
outputs/metrics/*.csv
outputs/metrics/*.json
outputs/metrics/*.txt
outputs/demo/*.png
outputs/demo/*.jpg
outputs/demo/*.jpeg

# Keep directory placeholders if used
!data/raw/.gitkeep
!data/processed/.gitkeep
!models/.gitkeep
!outputs/figures/.gitkeep
!outputs/metrics/.gitkeep
!outputs/demo/.gitkeep
